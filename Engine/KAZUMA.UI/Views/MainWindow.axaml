<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:KAZUMA.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="KAZUMA.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="K.A.Z.U.M.A - Asystent AI"
        Background="#1e1e1e"
        Foreground="White">

    <Window.Styles>
        <Style Selector="Ellipse.pulse">
            <Style.Animations>
                <Animation Duration="0:0:1" IterationCount="Infinite">
                    <KeyFrame KeyTime="0:0:0">
                        <Setter Property="Opacity" Value="0.3"/>
                        <Setter Property="ScaleTransform.ScaleX" Value="0.8"/>
                        <Setter Property="ScaleTransform.ScaleY" Value="0.8"/>
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:0.5">
                        <Setter Property="Opacity" Value="1.0"/>
                        <Setter Property="ScaleTransform.ScaleX" Value="1.2"/>
                        <Setter Property="ScaleTransform.ScaleY" Value="1.2"/>
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:1">
                        <Setter Property="Opacity" Value="0.3"/>
                        <Setter Property="ScaleTransform.ScaleX" Value="0.8"/>
                        <Setter Property="ScaleTransform.ScaleY" Value="0.8"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Window.Styles>

    <DockPanel Margin="10">
        <!-- Panel G├│rny -->
        <Border DockPanel.Dock="Top" Height="40" Background="#2d2d2d" CornerRadius="5" Margin="0,0,0,10">
            <TextBlock Text="K.A.Z.U.M.A - System Orchestrator" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
        </Border>

        <!-- Panel Dolny (Wej┼Ťcie) -->
        <StackPanel DockPanel.Dock="Bottom" Spacing="10" Margin="0,10,0,0">
            <Grid ColumnDefinitions="*, Auto, Auto">
                <TextBox Grid.Column="0" 
                         Text="{Binding InputText}" 
                         Watermark="Wpisz polecenie..."
                         VerticalContentAlignment="Center"/>
                <Button Grid.Column="1" 
                        Content="Wy┼Ťlij" 
                        Command="{Binding SendMessageCommand}"
                        Margin="5,0,0,0"
                        Background="#007acc"/>
                <Button Grid.Column="2" 
                        Content="Mów" 
                        Command="{Binding StartVoiceCommand}"
                        Margin="5,0,0,0"
                        Background="#28a745"/>
            </Grid>
        </StackPanel>

        <!-- Panel Chat (┼Ürodek) -->
        <Grid>
            <Border BorderBrush="#333333" BorderThickness="1" CornerRadius="5">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding ChatMessages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="5" Padding="10" Background="#2d2d2d" CornerRadius="5">
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
            
            <!-- Animacja Przetwarzania -->
             <StackPanel IsVisible="{Binding IsBusy}" 
                         VerticalAlignment="Bottom" 
                         HorizontalAlignment="Right" 
                         Margin="20" 
                         Orientation="Horizontal"
                         Spacing="15">
                 <TextBlock Text="K.A.Z.U.M.A my┼Ťli..." VerticalAlignment="Center" Foreground="#007acc" FontWeight="SemiBold"/>
                 <Ellipse Classes="pulse" Width="12" Height="12" Fill="#007acc"/>
                 <ProgressBar IsIndeterminate="True" Width="80" Height="4" Foreground="#007acc"/>
             </StackPanel>
        </Grid>
    </DockPanel>

</Window>
